{
  "name": "firetruss",
  "version": "8.0.0",
  "description": "Advanced data sync layer for Firebase and Vue.js",
  "scripts": {
    "update": "yarn up -R '*' && yarn dedupe --strategy highest",
    "latest": "yarn npm-check-updates -i -m --packageManager yarn --install never && yarn install",
    "upgrade": "reviewable-upgrade",
    "build": "yarn run grunt",
    "lint": "yarn grunt eslint",
    "test": "BABEL_DISABLE_CACHE=1 node --require @babel/register --test \"src/**/*.test.js\"",
    "finalize": "yarn run grunt replace default --release=\"$(jq -r .version package.json)\""
  },
  "repository": "https://github.com/Reviewable/firetruss",
  "keywords": [
    "firebase",
    "vuejs",
    "model",
    "worker"
  ],
  "author": "Piotr Kaminski",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Reviewable/firetruss/issues"
  },
  "homepage": "https://github.com/Reviewable/firetruss",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/register": "^8.0.1",
    "@rollup/plugin-commonjs": "29.x",
    "@rollup/plugin-node-resolve": "16.x",
    "compose-source-map": "^1.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "grunt": "^1.0.0",
    "grunt-contrib-clean": "2",
    "grunt-contrib-uglify": "5",
    "grunt-contrib-watch": "^1.0.0",
    "grunt-eslint": "26.x",
    "grunt-git": "^1.1.1",
    "grunt-rollup": "^12.0.0",
    "grunt-text-replace": "^0.4.0",
    "load-grunt-tasks": "5",
    "npm-check-updates": "^22.2.9",
    "reviewable-configs": "Reviewable/reviewable-configs#master",
    "rollup": "4.x"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "main": "dist/firetruss.umd.js",
  "module": "dist/firetruss.es2015.js",
  "types": "types/index.d.ts",
  "dependencies": {
    "lodash": "4",
    "vue": "^2.1.6"
  },
  "packageManager": "yarn@4.13.0"
}
